# ═══════════════════════════════════════════════════════════════════
# Cloudflare Pages — Security Headers, Cache Control & Early Hints
#
# ALL security headers are set here as static headers.
# The functions/_middleware.js is the future nonce-based CSP approach
# but requires Cloudflare Pages Functions to be enabled in the build.
# Until then, this file is the source of truth for all headers.
# ═══════════════════════════════════════════════════════════════════

# ─── Global Security Headers (all routes) ───
/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload
  Cross-Origin-Opener-Policy: same-origin-allow-popups
  Cross-Origin-Resource-Policy: same-origin
  Cross-Origin-Embedder-Policy: credentialless
  Permissions-Policy: geolocation=(), midi=(), sync-xhr=(), accelerometer=(), gyroscope=(), magnetometer=(), payment=(), usb=(), camera=(self), microphone=(self), fullscreen=(self)
  X-XSS-Protection: 0
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://www.googletagmanager.com https://www.google-analytics.com https://ddwl4m2hdecbv.cloudfront.net; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com data:; img-src 'self' data: blob: https:; connect-src 'self' https://chgrkvftjfibufoopmav.supabase.co wss://chgrkvftjfibufoopmav.supabase.co https://eu.i.posthog.com https://us.i.posthog.com https://generativelanguage.googleapis.com https://fonts.googleapis.com https://www.google-analytics.com https://www.googletagmanager.com https://ddwl4m2hdecbv.cloudfront.net https://region1.google-analytics.com; media-src 'self' blob: https:; frame-src https://www.youtube.com https://www.youtube-nocookie.com https://accounts.google.com https://www.google.com; object-src 'none'; base-uri 'self'; form-action 'self' https://accounts.google.com; frame-ancestors 'none'; worker-src 'self' blob:; manifest-src 'self'; upgrade-insecure-requests
  Link: <https://fonts.googleapis.com>; rel=preconnect
  Link: <https://fonts.gstatic.com>; rel=preconnect; crossorigin
  Link: <https://chgrkvftjfibufoopmav.supabase.co>; rel=preconnect; crossorigin
  Link: </quantum-logo.svg?v=8>; rel=preload; as=image; type=image/svg+xml
  Link: </quantum-logo-dark.png>; rel=preload; as=image; type=image/png
  Link: </quantum-club-logo.png>; rel=preload; as=image; type=image/png
  Link: <https://fonts.gstatic.com/s/inter/v20/UcC73FwrK3iLTeHuS_nVMrMxCp50SjIa1ZL7W0Q5nw.woff2>; rel=preload; as=font; type=font/woff2; crossorigin

# ─── SPA entry: always revalidate ───
/index.html
  Cache-Control: public, max-age=0, must-revalidate
/
  Cache-Control: public, max-age=0, must-revalidate

# ─── Service worker: never cache ───
/sw.js
  Cache-Control: no-cache, no-store, must-revalidate
  Expires: 0

# ─── PWA manifest: never cache ───
/manifest.webmanifest
  Cache-Control: no-cache, no-store, must-revalidate

# ─── Hashed Vite assets: immutable forever ───
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# ─── Non-hashed static assets: cache with revalidation ───
/favicon.png
  Cache-Control: public, max-age=86400, must-revalidate
/favicon.ico
  Cache-Control: public, max-age=86400, must-revalidate
/favicon-*.png
  Cache-Control: public, max-age=86400, must-revalidate
/quantum-logo.svg
  Cache-Control: public, max-age=86400, must-revalidate
/quantum-logo-dark.png
  Cache-Control: public, max-age=86400, must-revalidate
/quantum-club-logo.png
  Cache-Control: public, max-age=86400, must-revalidate
/icon-*.png
  Cache-Control: public, max-age=604800, must-revalidate
/apple-touch-icon*.png
  Cache-Control: public, max-age=604800, must-revalidate
